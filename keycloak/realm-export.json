{
  "realm": "guard-bands",
  "displayName": "Guard Bands",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "bruteForceProtected": true,
  "accessTokenLifespan": 3600,
  "clients": [
    {
      "clientId": "guard-bands-api",
      "name": "Guard Bands API",
      "description": "oauth2-proxy confidential client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-client-secret-change-in-prod",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:4180/oauth2/callback"
      ],
      "webOrigins": [
        "http://localhost:4180"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4180/"
      }
    }
  ],
  "users": [
    {
      "username": "testuser",
      "email": "testuser@example.com",
      "firstName": "Test",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "testpass123",
          "temporary": false
        }
      ]
    }
  ]
}
