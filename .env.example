# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

DEBUG=false

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:4180

# LLM model used by /chat
LLM_MODEL=claude-3-5-haiku-20241022

# --- Audit logging ---

# PostgreSQL (managed automatically by docker compose; set DSN for direct uvicorn dev)
LOG_POSTGRES_DSN=postgresql://guard_bands:changeme@localhost:5432/guard_bands

# Splunk HEC (leave blank to disable)
LOG_SPLUNK_HEC_URL=https://splunk.example.com:8088
LOG_SPLUNK_HEC_TOKEN=
LOG_SPLUNK_INDEX=guard_bands
LOG_SPLUNK_SOURCE=guard-bands-api
LOG_SPLUNK_SSL_VERIFY=true

# --- SSO (oauth2-proxy + Keycloak) ---

# false = no auth enforced (local uvicorn dev)
# true  = enforced; set automatically by docker-compose for the app service
SSO_ENABLED=false

# Header names injected by oauth2-proxy --pass-user-headers=true
# X-Forwarded-User  → request.state.user_id in the app
# X-Forwarded-Email → request.state.user_email (logged in audit events)
# Override here if using a different proxy that sends different header names
SSO_HEADER_USER=X-Forwarded-User
SSO_HEADER_EMAIL=X-Forwarded-Email

# Keycloak admin credentials (docker compose only)
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak client secret — must match keycloak/realm-export.json "secret" field
# Change both together when moving to production
KC_CLIENT_SECRET=dev-client-secret-change-in-prod

# oauth2-proxy 32-byte base64 cookie secret
# Generate: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
OAUTH2_PROXY_COOKIE_SECRET=Z3VhcmQtYmFuZHMtZGV2LWNvb2tpZS1zZWNyZXQhISE=

# Docker Compose postgres password
POSTGRES_PASSWORD=changeme
