# Production-shape configuration template.
# Copy to .env.production and fill in real values (or resolve them from a
# secrets manager via SECRETS_BACKEND). Never commit the filled-in file.

# ── Secrets backend ───────────────────────────────────────────────
# env    → read secrets from environment variables (inject via your
#          orchestrator: Vault Agent, ECS task secrets, K8s External Secrets)
# aws    → AWS Secrets Manager  (pip install 'guard-bands[aws]')
# vault  → HashiCorp Vault KV v2 (pip install 'guard-bands[vault]')
SECRETS_BACKEND=env

# AWS backend (when SECRETS_BACKEND=aws). Secret ids are {PREFIX}{NAME},
# e.g. prod/guard-bands/SECRET_KEY.
# SECRETS_AWS_PREFIX=prod/guard-bands/
# SECRETS_AWS_REGION=us-east-1

# Vault backend (when SECRETS_BACKEND=vault). Reads {MOUNT}/{PREFIX}{NAME}, field "value".
# VAULT_ADDR=https://vault.your-domain.example:8200
# VAULT_TOKEN=<token or use an auth method / agent>
# SECRETS_VAULT_MOUNT=secret
# SECRETS_VAULT_PREFIX=guard-bands/

# ── Core secrets (resolved via SECRETS_BACKEND) ───────────────────
# With SECRETS_BACKEND=env, set them here. With aws/vault, store them there
# under the matching name and leave these blank.
SECRET_KEY=
KEY_ID=key-2026-07
# Rotation map: active KEY_ID signs; retired ids verify during rollover.
GUARD_BAND_KEYS={"key-2026-07":"active-secret","key-2026-06":"previous-secret"}
ANTHROPIC_API_KEY=

# ── Hardened runtime settings ─────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=https://your-app.example.com
GUARD_BAND_TTL_SECONDS=900

# Replay protection ON, persisted. Use a shared backend for >1 replica.
REPLAY_PROTECTION_ENABLED=true
REPLAY_LEDGER_BACKEND=sqlite
REPLAY_LEDGER_PATH=data/replay-ledger.sqlite3
REPLAY_WINDOW_SECONDS=900

# SSO enforced (reject unauthenticated requests not from the proxy).
SSO_ENABLED=true

# Cost guard — set prices to match LLM_MODEL.
LLM_MODEL=claude-3-5-haiku-20241022
LLM_MAX_OUTPUT_TOKENS=2048
COST_GUARD_ENABLED=true
COST_GUARD_THRESHOLD_USD=1.00
COST_GUARD_INPUT_USD_PER_MTOK=1.00
COST_GUARD_OUTPUT_USD_PER_MTOK=5.00

# ── Audit (resolved via SECRETS_BACKEND where secret-bearing) ─────
LOG_POSTGRES_DSN=
LOG_SPLUNK_HEC_URL=
LOG_SPLUNK_HEC_TOKEN=
LOG_SPLUNK_SSL_VERIFY=true

# ── Stack secrets (docker compose prod overlay) ───────────────────
POSTGRES_PASSWORD=
KEYCLOAK_ADMIN_PASSWORD=
KC_CLIENT_SECRET=
